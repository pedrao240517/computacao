algoritmo "matriz 10x10 com pares e impares"
var
M : vetor[1..10, 1..10] de inteiro
l,c,p,inp:inteiro
inicio
     para l <- 1 ate 10 faca
      para c  <- 1 ate 10 faca
            Escreval("Digite o valor da matriz: [",l,",",c,"]")
            Leia(M[l,c])
      fimpara
     fimpara
     Escreval("_______________________________________________________________________________________________________________________________")
     Escreval("                                                           MATRIZ                                ")
     Escreval("_______________________________________________________________________________________________________________________________")
     para l <- 1 ate 10 faca
      para c <- 1 ate 10 faca
           Escreva(M[l,c]:8)
           se (M[l,c] %2 = 0 ) entao
                p <- p +1
           senao
                inp <- inp +1
           fimse
           se (M[l,c] %2 = 0 ) entao
              Escreva("{",m[l,c]:2,"}")
           senao
                Escreva(M[l,c]:4)
           fimse
      fimpara
             Escreval()
     fimpara
     Escreval("Os n·meros em colchetes sŃo pares.")
     Escreval("Os n·meros fora dos  colchetes sŃo impares.")
     Escreval("Existem ",p," n·meros pares nessa matriz")
     Escreval("Existem ",inp," n·meros pares nessa matriz")
fimalgoritmo