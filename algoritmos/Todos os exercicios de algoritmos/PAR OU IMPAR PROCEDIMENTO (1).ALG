algoritmo "par ou impar procedimento"
var
    N:inteiro
Procedimento parouimpar(V: inteiro)
inicio
   Se (V%2 = 0 ) entao
      Escreva("O n·mero ", V, " ķ par")
   senao
        Escreva(" O n·mero ", V, " ķ impar")
   fimse
fimprocedimento
inicio
      Escreva("Digite um n·mero: ")
      Leia(N)
      parouimpar(N)
fimalgoritmo