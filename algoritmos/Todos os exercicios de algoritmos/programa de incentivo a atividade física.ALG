algoritmo "semnome"
var
    H, R, P:real
inicio
      Escreva("Quantas horas de atividade física vocę fez no męs? ")
      leia(H)
      Se (H < 10) entao
         P <- H*2
         Escreval("Vocę recebeu ",P, " pontos")
      senao
           Se (H >= 10) e (H <= 20) entao
              P <- H*5
              Escreval("Vocę recebeu",P, " pontos")
           senao
                se (H > 20) entao
                   P <- H*10
                   Escreval("Vocę recebeu ",P, " pontos")
                fimse
           fimse
      fimse
      R <- P * 0.05
      Escreva("Vocę vai receber ",R," reais pelos pontos conquistados")
         
fimalgoritmo